{
  "name": "swarm",
  "version": "0.0.1",
  "description": "Standalone TypeScript swarm CLI — fan out agents, collect structured output, synthesize",
  "type": "module",
  "bin": {
    "swarm": "dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown && mkdir -p dist/agents/bundled && cp src/agents/bundled/* dist/agents/bundled/",
    "dev": "tsdown --watch",
    "start": "node dist/cli.mjs",
    "lint": "eslint src",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:e2e": "pnpm build && vitest run --config vitest.e2e.config.ts"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  }
}
